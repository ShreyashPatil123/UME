# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{cpp,hpp,c,h,cc,hh,cxx,hxx}]
indent_size = 4

[*.{rs,py,ts,tsx,js,jsx}]
indent_size = 4

[*.{yml,yaml,json,md,html,css}]
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab
